# ─── Fournisseurs LLM (routage par tâche) ──────────────────────────
# Renseignez UNE OU PLUSIEURS clés : le routeur choisit automatiquement le
# modèle selon la tâche (léger pour chat/conception, puissant pour code/réparation).
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...            # (ou GOOGLE_API_KEY)

# Exemple recommandé pour optimiser le coût : Gemini (léger) + Anthropic (fort)
#   → chat/conception/revue = Gemini Flash ; codegen/réparation = Opus

# Surcharge fine par tâche (facultatif) : provider[:model]
#   TASK ∈ CHAT | DESIGN | CODEGEN | REPAIR | REVIEW
# LLM_ROUTE_CODEGEN=anthropic:claude-opus-4-8
# LLM_ROUTE_CHAT=gemini:gemini-2.0-flash

# Forcer un fournisseur unique pour tout (désactive le routage auto) :
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-opus-4-8

# ─── Session / persistance ─────────────────────────────────────────
# NEORA_SESSION_SECRET=change-me-en-prod
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
